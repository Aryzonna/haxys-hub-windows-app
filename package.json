{
  "name": "haxyshub",
  "productName": "Haxys Hub",
  "version": "1.0.8",
  "description": "Haxys Hub - Plataforma de gestão empresarial",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "dist": "electron-builder --win"
  },
  "build": {
    "appId": "com.haxys.hub",
    "productName": "Haxys Hub",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "artifactName": "HaxysHub-Setup.exe"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "shortcutName": "Haxys Hub",
      "uninstallDisplayName": "Haxys Hub",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerSidebar": null,
      "include": "build/installer.nsh"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "asar": true,
    "publish": {
      "provider": "github",
      "owner": "Aryzonna",
      "repo": "haxys-hub-windows-app",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "electron-updater": "^6.1.7"
  },
  "devDependencies": {
    "electron": "~35.0.0",
    "@electron-forge/cli": "^7.0.0",
    "@electron-forge/maker-squirrel": "^7.0.0",
    "@electron-forge/maker-zip": "^7.0.0",
    "@electron-forge/plugin-auto-unpack-natives": "^7.0.0",
    "electron-builder": "^26.0.0"
  },
  "author": "Haxys",
  "license": "MIT"
}
